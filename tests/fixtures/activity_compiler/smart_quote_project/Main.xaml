<Activity x:Class="Main"
          xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
          xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation"
          xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Sequence DisplayName="Body">
    <Sequence.Variables>
      <Variable x:TypeArguments="x:String" Name="vSmartQuote" Default="“hello world”" />
    </Sequence.Variables>
    <Assign DisplayName="AssignSmartQuote">
      <Assign.To>
        <OutArgument x:TypeArguments="x:String">[vSmartQuote]</OutArgument>
      </Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">[“hello world”]</InArgument>
      </Assign.Value>
    </Assign>
  </Sequence>
</Activity>
